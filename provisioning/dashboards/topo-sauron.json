          "nodes": [
            {
              "id": "cf",
              "name": "Cloudflare CDN",
              "role": "60+ zones",
              "type": "cloudflare",
              "position": {
                "x": 300,
                "y": 0
              },
              "compact": false,
              "width": 180,
              "metrics": [
                {
                  "id": "cf-rps",
                  "label": "rps",
                  "datasourceUid": "prod-prometheus",
                  "query": "sum(rate(cloudflare_zone_requests_total[5m]))",
                  "format": "${value} rps",
                  "section": "General",
                  "isSummary": true,
                  "showSparkline": false,
                  "thresholds": [
                    {
                      "value": 0,
                      "color": "green"
                    },
                    {
                      "value": 100,
                      "color": "yellow"
                    }
                  ]
                }
              ]
            },
