{
  "name": "sid2-grafana-topology",
  "version": "1.0.0",
  "description": "E2E Topology Diagram Panel with live metrics, drag-and-drop, animated flow connections, and expandable metric panels",
  "scripts": {
    "build": "TS_NODE_COMPILER_OPTIONS={\"module\":\"commonjs\"} webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "TS_NODE_COMPILER_OPTIONS={\"module\":\"commonjs\"} webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache --ignore-path ./.gitignore --ext .js,.jsx,.ts,.tsx .",
    "sign": "npx @grafana/sign-plugin@latest",
    "server": "docker compose up --build"
  },
  "author": "SID2 Platform Engineering",
  "license": "Apache-2.0",
  "devDependencies": {
    "@grafana/eslint-config": "^7.0.0",
    "@grafana/plugin-e2e": "^1.0.0",
    "@grafana/tsconfig": "^2.0.0",
    "@swc/core": "^1.3.90",
    "@swc/helpers": "^0.5.0",
    "@swc/jest": "^0.2.29",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.0",
    "@types/lodash": "^4.14.200",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.0",
    "eslint": "^8.50.0",
    "eslint-webpack-plugin": "^4.2.0",
    "fork-ts-checker-webpack-plugin": "^9.0.0",
    "glob": "^10.3.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.0.0",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "^1.60.0",
    "sass-loader": "^13.3.0",
    "style-loader": "^3.3.0",
    "swc-loader": "^0.2.3",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-virtual-modules": "^0.6.2"
  },
  "dependencies": {
    "@grafana/data": "^10.0.0",
    "@grafana/runtime": "^10.0.0",
    "@grafana/ui": "^10.0.0",
    "lodash": "^4.17.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "engines": {
    "node": ">=18"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node",
      "esModuleInterop": true
    }
  }
}
